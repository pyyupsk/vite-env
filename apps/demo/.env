# Server-only variables (never reach the browser)
DATABASE_URL=postgresql://localhost:5432/mydb
JWT_SECRET=this-is-a-super-secret-jwt-key-that-is-at-least-32-chars
DB_POOL_SIZE=5

# Client variables (VITE_ prefix — available in browser)
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=vite-env-demo
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

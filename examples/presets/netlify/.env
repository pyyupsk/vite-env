# Vars Netlify injects at build time — dummy values for local runs
NETLIFY=true
BUILD_ID=build_example123
CONTEXT=dev
DEPLOY_ID=deploy_example123
DEPLOY_URL=https://deploy-example123--myapp.netlify.app
DEPLOY_PRIME_URL=https://deploy-preview-1--myapp.netlify.app
URL=https://myapp.netlify.app
BRANCH=main
COMMIT_REF=0000000000000000000000000000000000000000

# Your own vars
DATABASE_URL=postgres://user:password@localhost:5432/app
VITE_APP_NAME=vite-env netlify preset example

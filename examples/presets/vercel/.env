# Vars Vercel injects at build time — dummy values for local runs
VERCEL=1
VERCEL_ENV=development
VERCEL_URL=myapp-abc123.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=myapp.vercel.app
VERCEL_DEPLOYMENT_ID=dpl_example123

# Your own vars
DATABASE_URL=postgres://user:password@localhost:5432/app
VITE_APP_NAME=vite-env vercel preset example

{
  "name": "@vite-env/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*",
      "examples/*",
      "examples/presets/*"
    ],
    "catalog": {
      "@standard-schema/spec": "^1.1.0",
      "jiti": "^2.6.1"
    },
    "catalogs": {
      "cli": {
        "citty": "^0.2.2",
        "consola": "^3.4.2"
      },
      "dev": {
        "@pyyupsk/nit": "^0.3.0",
        "@types/node": "^25.9.2",
        "@vitest/coverage-v8": "^4.1.8",
        "bumpp": "^11.1.0",
        "oxfmt": "latest",
        "oxlint": "latest",
        "tsdown": "^0.21.7",
        "typescript": "^6.0.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.8",
        "zod": "^4.3.6"
      },
      "docs": {
        "@fontsource-variable/geist": "^5.2.9",
        "@fontsource-variable/geist-mono": "^5.2.8",
        "@tailwindcss/vite": "^4.1.11",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.17.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "rehype-slug": "^6.0.0",
        "shiki": "^4.2.0",
        "tailwind-merge": "^3.6.0",
        "velite": "^0.3.1",
        "wouter": "^3.3.0"
      },
      "examples": {
        "valibot": "^1.3.1"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "prepare": "nit install",
    "release": "bumpp -r",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest run --watch",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@pyyupsk/nit": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "bumpp": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "vite": ">=8.0.5"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "nit": {
    "hooks": {
      "pre-commit": {
        "stages": {
          "**/*": "bunx oxlint --fix {staged_files}"
        }
      }
    }
  },
  "trustedDependencies": [
    "@pyyupsk/nit",
    "esbuild"
  ]
}

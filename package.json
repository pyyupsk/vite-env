{
  "name": "@vite-env/monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "lint": "eslint . --cache --concurrency=auto",
    "lint:fix": "eslint . --cache --concurrency=auto --fix",
    "prepare": "nit install",
    "release": "bumpp -r",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest run --watch",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@pyyupsk/eslint-config": "catalog:dev",
    "@pyyupsk/nit": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "bumpp": "catalog:dev",
    "eslint": "catalog:dev",
    "lint-staged": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "@pyyupsk/nit",
    "esbuild"
  ],
  "overrides": {
    "esbuild": ">=0.25.0",
    "vite": ">=8.0.5"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@standard-schema/spec": "^1.1.0",
      "jiti": "^2.6.1"
    },
    "catalogs": {
      "demo": {
        "valibot": "^1.3.1"
      },
      "dev": {
        "@eslint/js": "^10.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "shiki": "^4.2.0",
        "tailwind-merge": "^3.6.0",
        "@fontsource-variable/geist": "^5.2.9",
        "@fontsource-variable/geist-mono": "^5.2.8",
        "@tailwindcss/vite": "^4.1.11",
        "@pyyupsk/eslint-config": "^0.3.0",
        "@pyyupsk/nit": "^0.1.0",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.2",
        "bumpp": "^11.0.1",
        "citty": "^0.2.2",
        "consola": "^3.4.2",
        "eslint": "^10.2.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "lint-staged": "^16.4.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "tsdown": "^0.21.7",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.2",
        "lucide-react": "^1.17.0",
        "zod": "^4.3.6"
      }
    }
  },
  "nit": {
    "hooks": {
      "pre-commit": "bun install --frozen-lockfile && bunx lint-staged"
    }
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}

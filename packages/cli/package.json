{
  "name": "@vite-env/cli",
  "type": "module",
  "version": "0.1.0",
  "description": "CLI for @vite-env/core — check, generate, types",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index-JtcdNmdz.d.ts",
  "bin": {
    "vite-env": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],

    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vite-env/core": "workspace:*",
    "citty": "catalog:dev",
    "consola": "catalog:dev",
    "zod": "catalog:dev"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev"
  }

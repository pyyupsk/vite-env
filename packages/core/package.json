{
  "name": "@vite-env/core",
  "type": "module",
  "version": "0.1.0",
  "description": "The env.ts layer for Vite — define once, validate everywhere, import with types",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./dts": {
      "import": "./dist/dts.mjs",
      "require": "./dist/dts.cjs"
    },
    "./format": {
      "import": "./dist/format.mjs",
      "require": "./dist/format.cjs"
    },
    "./leak": {
      "import": "./dist/leak.mjs",
      "require": "./dist/leak.cjs"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.cjs"
    },
    "./schema": {
      "import": "./dist/schema.mjs",
      "require": "./dist/schema.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "zod": "catalog:dev"
  }
}

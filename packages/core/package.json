{
  "name": "@vite-env/core",
  "type": "module",
  "version": "0.1.0",
  "description": "The env.ts layer for Vite — define once, validate everywhere, import with types",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.mjs",
    "./dts": "./dist/dts.mjs",
    "./format": "./dist/format.mjs",
    "./leak": "./dist/leak.mjs",
    "./plugin": "./dist/plugin.mjs",
    "./schema": "./dist/schema.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "zod": "catalog:dev"
  }
}

{
  "name": "@vite-env/core",
  "type": "module",
  "version": "0.2.0",
  "description": "The env.ts layer for Vite — define once, validate everywhere, import with types",
  "license": "MIT",
  "homepage": "https://github.com/pyyupsk/vite-env#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyyupsk/vite-env.git",
    "directory": "packages/core"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "environment-variables",
    "env",
    "typescript",
    "zod",
    "validation",
    "rolldown",
    "dotenv"
  ],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./config": {
      "import": { "types": "./dist/config.d.mts", "default": "./dist/config.mjs" },
      "require": { "types": "./dist/config.d.cts", "default": "./dist/config.cjs" }
    },
    "./dts": {
      "import": { "types": "./dist/dts.d.mts", "default": "./dist/dts.mjs" },
      "require": { "types": "./dist/dts.d.cts", "default": "./dist/dts.cjs" }
    },
    "./format": {
      "import": { "types": "./dist/format.d.mts", "default": "./dist/format.mjs" },
      "require": { "types": "./dist/format.d.cts", "default": "./dist/format.cjs" }
    },
    "./leak": {
      "import": { "types": "./dist/leak.d.mts", "default": "./dist/leak.mjs" },
      "require": { "types": "./dist/leak.d.cts", "default": "./dist/leak.cjs" }
    },
    "./plugin": {
      "import": { "types": "./dist/plugin.d.mts", "default": "./dist/plugin.mjs" },
      "require": { "types": "./dist/plugin.d.cts", "default": "./dist/plugin.cjs" }
    },
    "./schema": {
      "import": { "types": "./dist/schema.d.mts", "default": "./dist/schema.mjs" },
      "require": { "types": "./dist/schema.d.cts", "default": "./dist/schema.cjs" }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=8.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "jiti": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "zod": "catalog:dev"
  }
}

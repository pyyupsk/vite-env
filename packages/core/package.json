{
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "name": "@vite-env/core",
  "version": "0.6.4",
  "description": "The env.ts layer for Vite — define once, validate everywhere, import with types",
  "keywords": [
    "dotenv",
    "env",
    "environment-variables",
    "standard-schema",
    "typescript",
    "validation",
    "vite",
    "vite-plugin",
    "zod"
  ],
  "homepage": "https://github.com/pyyupsk/vite-env#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyyupsk/vite-env.git",
    "directory": "packages/core"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    },
    "./dts": {
      "import": {
        "types": "./dist/dts.d.mts",
        "default": "./dist/dts.mjs"
      },
      "require": {
        "types": "./dist/dts.d.cts",
        "default": "./dist/dts.cjs"
      }
    },
    "./format": {
      "import": {
        "types": "./dist/format.d.mts",
        "default": "./dist/format.mjs"
      },
      "require": {
        "types": "./dist/format.d.cts",
        "default": "./dist/format.cjs"
      }
    },
    "./load": {
      "import": {
        "types": "./dist/load.d.mts",
        "default": "./dist/load.mjs"
      },
      "require": {
        "types": "./dist/load.d.cts",
        "default": "./dist/load.cjs"
      }
    },
    "./leak": {
      "import": {
        "types": "./dist/leak.d.mts",
        "default": "./dist/leak.mjs"
      },
      "require": {
        "types": "./dist/leak.d.cts",
        "default": "./dist/leak.cjs"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/plugin.d.mts",
        "default": "./dist/plugin.mjs"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema.d.mts",
        "default": "./dist/schema.mjs"
      },
      "require": {
        "types": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      }
    },
    "./standard": {
      "import": {
        "types": "./dist/standard.d.mts",
        "default": "./dist/standard.mjs"
      },
      "require": {
        "types": "./dist/standard.d.cts",
        "default": "./dist/standard.cjs"
      }
    },
    "./presets": {
      "import": {
        "types": "./dist/presets/index.d.mts",
        "default": "./dist/presets/index.mjs"
      },
      "require": {
        "types": "./dist/presets/index.d.cts",
        "default": "./dist/presets/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:",
    "jiti": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "zod": "catalog:dev"
  },
  "peerDependencies": {
    "vite": ">=8.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": ">=8.0.0"
    },
    "rollup": {
      "type": "incompatible",
      "reason": "Uses Vite-specific hooks (configResolved, configureServer) and APIs (ResolvedConfig, Environment API) not available in standalone Rollup."
    },
    "rolldown": {
      "type": "incompatible",
      "reason": "Uses Vite-specific hooks (configResolved, configureServer) and APIs (ResolvedConfig, Environment API) not available in standalone Rolldown."
    }
  }
}
